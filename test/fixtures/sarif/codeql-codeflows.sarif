{
  "version": "2.1.0",
  "$schema": "https://json.schemastore.org/sarif-2.1.0.json",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "CodeQL",
          "semanticVersion": "2.17.0",
          "rules": [
            {
              "id": "js/path-injection",
              "shortDescription": {
                "text": "Path injection"
              },
              "properties": {
                "tags": [
                  "security",
                  "external/cwe/cwe-022"
                ],
                "precision": "high"
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/22.html"
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "js/path-injection",
          "ruleIndex": 0,
          "level": "error",
          "message": {
            "text": "User-controlled path reaches fs.readFile."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "/src/routes/download.js"
                },
                "region": {
                  "startLine": 88,
                  "endLine": 88,
                  "snippet": {
                    "text": "fs.readFile(req.query.path)"
                  }
                }
              }
            }
          ],
          "codeFlows": [
            {
              "threadFlows": [
                {
                  "locations": [
                    {
                      "location": {
                        "physicalLocation": {
                          "artifactLocation": {
                            "uri": "/src/routes/download.js"
                          },
                          "region": {
                            "startLine": 12
                          }
                        }
                      }
                    },
                    {
                      "location": {
                        "physicalLocation": {
                          "artifactLocation": {
                            "uri": "/src/routes/download.js"
                          },
                          "region": {
                            "startLine": 88
                          }
                        }
                      }
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
