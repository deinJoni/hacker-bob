--- /dev/null
+++ b/src/db.js
@@ -0,0 +1,12 @@
+const knex = require('knex');
+
+const db = knex({
+  client: 'pg',
+  connection: {
+    host: process.env.DB_HOST || 'localhost',
+    database: process.env.DB_NAME || 'app',
+    user: process.env.DB_USER || 'app',
+    password: process.env.DB_PASS || 'change_me_in_production',
+  },
+});
+module.exports = db;
